{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && go build ./... || true",
            "timeout": 30,
            "statusMessage": "Checking Go compilation..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git commit' && bash .claude/scripts/update-docs.sh || true",
            "timeout": 180,
            "statusMessage": "Updating project documentation..."
          }
        ]
      }
    ]
  }
}
